<?xml version="1.0" encoding="utf-8"?>
<Project>
  <!-- This file is automatically imported by NuGet when the package is referenced -->

  <!-- Copy the test adapter to the output directory so VSTest can discover it -->
  <ItemGroup>
    <Content Include="$(MSBuildThisFileDirectory)../lib/net9.0/Sailfish.TestAdapter.dll" Condition="'$(TargetFramework)' == 'net9.0' and Exists('$(MSBuildThisFileDirectory)../lib/net9.0/Sailfish.TestAdapter.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
    <Content Include="$(MSBuildThisFileDirectory)../lib/net10.0/Sailfish.TestAdapter.dll" Condition="'$(TargetFramework)' == 'net10.0' and Exists('$(MSBuildThisFileDirectory)../lib/net10.0/Sailfish.TestAdapter.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>False</Visible>
    </Content>
  </ItemGroup>

  <!--
    Ensure the test adapter is available for test discovery.

    Path.GetFullPath normalizes the '..' segment so the resulting item is a
    plain absolute path. Some hosts (notably ReSharper / Rider) resolve
    TestAdapterPath items relative to a working directory other than the
    project root and don't collapse '..' on their own — handing them the
    raw '$(MSBuildThisFileDirectory)../lib/<tfm>/' form leaves the adapter
    undiscoverable. See PR #225 for the matching fix on the project-ref path.
  -->
  <ItemGroup>
    <TestAdapterPath Include="$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)../lib/net9.0/'))" Condition="'$(TargetFramework)' == 'net9.0'" />
    <TestAdapterPath Include="$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)../lib/net10.0/'))" Condition="'$(TargetFramework)' == 'net10.0'" />
  </ItemGroup>

  <!-- Copy ALL runtime dependencies to output directory -->
  <Target Name="CopySailfishDependencies" AfterTargets="ResolvePackageAssets">
    <ItemGroup>
      <!-- Copy all runtime assemblies - no filtering needed -->
      <ContentWithTargetPath Include="@(RuntimeCopyLocalItems)">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <TargetPath>%(Filename)%(Extension)</TargetPath>
      </ContentWithTargetPath>
    </ItemGroup>
  </Target>

</Project>